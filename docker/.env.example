# Nach .env kopieren und anpassen:  cp docker/.env.example docker/.env

# Zeitzone des Containers (fuer korrekte Log-Zeitstempel)
TIME_ZONE=Europe/Berlin

# Hinweis Netzwerk:
# compose.yaml nutzt ein externes Docker-Netzwerk namens "web_net".
# Vorhandene Netzwerke anzeigen:        docker network ls
# Eigenes externes Netz anlegen:        docker network create web_net
# Oder den networks-Block in compose.yaml an die eigene Umgebung anpassen.
